---
const PROJECTS = [
	{
		title: "prakhars17.dev",
		blurb:
			"A revamped personal site: crafted with design and development principles.",
		tags: ["Astro", "Tailwind", "Claude Design"],
		href: "#top",
	},
];
---

<section id="projects" class="section-wrapper" aria-labelledby="projects-label">
	<h2 id="projects-label" class="section-label">
		<span class="text-(--accent)">03</span> &nbsp;— &nbsp;Selected projects
	</h2>

	<div class="grid gap-5">
		{
			PROJECTS.map((project) => (
				<article class="rounded-xl border border-(--border) bg-(--card) p-6.5">
					<div class="mb-3 title-row">
						<h3>
							<a
								href={project.href}
								rel="noopener noreferrer"
								aria-label={project.title}
								class="title-link"
							>
								{project.title}
								<span
									class="ml-1 inline-block no-underline"
									aria-hidden="true"
								>
									↗
								</span>
							</a>
						</h3>
						<span class="whitespace-nowrap text-[12px] lowercase text-(--faint)">
							Case study
						</span>
					</div>
					<p class="mb-4.5 max-w-[58ch] text-pretty text-[16px] leading-[1.6] text-(--ink-soft)">
						{project.blurb}
					</p>
					<div class="mb-4.5 flex flex-wrap gap-1.75">
						{project.tags.map((tag) => (
							<span class="rounded-[5px] border border-(--border) px-2.25 py-0.75 text-[12px] text-(--muted)">
								{tag}
							</span>
						))}
					</div>
					<a href={project.href} class="link-soft text-[12px]">
						View case study
						<span
							class="ml-1 inline-block no-underline"
							aria-hidden="true"
						>
							→
						</span>
					</a>
				</article>
			))
		}
	</div>
</section>
