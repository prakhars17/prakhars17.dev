---
import { Image } from "astro:assets";
import me from "../assets/images/me.jpeg";
import { config } from "../data/config";

const socialLinks = [
	{
		href: config.socials.github,
		label: "GitHub",
		icon: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>`,
	},
	{
		href: config.socials.linkedin,
		label: "LinkedIn",
		icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
	},
];
---

<header class="pt-37 pb-24">
	<div class="mb-10 grid grid-cols-[auto_1fr] items-center gap-7">
		<div
			class="size-40 overflow-hidden rounded-full border border-(--border)"
		>
			<Image
				src={me}
				width={320}
				alt={config.name.full}
				loading="eager"
				class="size-full object-cover"
			/>
		</div>
		<div class="flex flex-col gap-1.5">
			<span class="text-[20px] font-medium text-(--ink)"
				>{config.name.first}</span
			>
			<span class="text-[13px] lowercase tracking-widest text-(--muted)"
				>{config.role}</span
			>
		</div>
	</div>

	<h1
		class="mb-5.5 text-pretty text-[clamp(42px,7vw,64px)] font-bold leading-[1.08] tracking-tight text-(--ink)"
	>
		I build and <span class="text-(--accent)">own</span> what I ship.
	</h1>

	<p
		class="mb-7.5 max-w-[62ch] text-pretty text-[18px] leading-[1.65] text-(--ink-mid)"
	>
		Six-plus years building products, not just screens. I take rough ideas
		and turn them into software people use, working across the stack
		wherever the product needs me most. I've built products in insurance,
		travel, and manufacturing.
	</p>

	<div class="mb-7.5 flex flex-wrap items-center gap-3.5">
		<a
			href={`mailto:${config.email}`}
			class="inline-flex items-center gap-2 rounded-lg bg-(--accent) px-5 py-3 text-[14px] font-medium text-(--bg) transition duration-250 hover:brightness-92"
		>
			Email me
		</a>
		<a
			href={`/${config.resume}`}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Resume opens in a new tab"
			class="inline-flex items-center gap-2 rounded-lg border border-(--btn-border) px-4.5 py-3 text-[14px] font-medium text-(--ink) transition duration-250 hover:border-(--faint) hover:bg-(--card)"
		>
			Resume <span class="text-[13px]" aria-hidden="true">↗</span>
		</a>
	</div>

	<div class="flex items-center gap-5.5">
		{
			socialLinks.map(({ href, label, icon }) => (
				<a
					href={href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`${label} opens in a new tab`}
					class="link-soft flex items-center gap-1.5"
				>
					<svg class="w-4.5 h-4.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={icon} />
					{label}
				</a>
			))
		}
	</div>
</header>
