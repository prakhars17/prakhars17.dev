---
import { config } from "../data/config";

const WORK = [
	{
		company: "Guardian Life",
		period: "Dec 2024 — Now",
		jobTitle: "Senior Software Engineer",
		summary:
			"Rebuilt the dental cost estimator in Next.js 15 so members can compare in-network and out-of-network costs before booking. We shipped it behind LaunchDarkly flags to all 4M+ eligible members once it cleared WCAG 2.1 AA, pushing task completion past 75%. I also worked across the member dashboard revamp serving 5M+ members.",
	},
];
---

<section id="work" class="section-wrapper" aria-labelledby="work-label">
	<h2 id="work-label" class="section-label">
		<span class="text-(--accent)">02</span> &nbsp;— &nbsp;Work
	</h2>

	{
		WORK.map((role, index) => (
			<div
				class:list={[
					"pb-6",
					{ "border-t border-(--hairline) pt-6": index > 0 },
				]}
			>
				<div class="mb-1.5 title-row">
					<h3 class="text-[21px] font-medium tracking-[-0.01em] text-(--ink)">
						{role.company}
					</h3>
					<span class="whitespace-nowrap text-[12px] text-(--faint)">
						{role.period}
					</span>
				</div>
				<div class="mb-3.5 text-[15px] text-(--muted)">
					{role.jobTitle}
				</div>
				<p class="max-w-[62ch] text-pretty text-[16px] leading-[1.6] text-(--ink-soft)">
					{role.summary}
				</p>
			</div>
		))
	}

	<p
		class="max-w-[62ch] text-pretty border-t border-(--hairline) pt-6 text-[16px] leading-[1.6] text-(--ink-soft)"
	>
		Before Guardian, I built products for startups across travel and
		manufacturing.
		<br />
		More on{" "}
		<a
			target="_blank"
			class="link-soft"
			rel="noopener noreferrer"
			href={config.socials.linkedin}
			aria-label="LinkedIn opens in a new tab"
		>
			LinkedIn
			<span class="ml-1 inline-block no-underline" aria-hidden="true">
				↗
			</span>
		</a>
	</p>
</section>
