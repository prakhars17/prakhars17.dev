---
const WORK = [
	{
		title: "Senior Software Engineer",
		period: "Dec 2024 — Now",
		company: "Guardian Life",
		before:
			"Reworked the main dashboard's render path. Median load dropped from ",
		metric: "2.4s to 0.9s",
		after: " and weekly active use rose 18%.",
	},
];
---

<section id="work" class="section-wrapper">
	<div class="section-label">
		<span class="text-(--accent)">02</span> &nbsp;— &nbsp;Work
	</div>

	{
		WORK.map((role) => (
			<div class="border-t border-(--hairline) py-6">
				<div class="mb-1.5 title-row">
					<h3 class="text-[21px] font-medium tracking-[-0.01em] text-(--ink)">
						{role.title}
					</h3>
					<span class="whitespace-nowrap text-[12px] text-(--faint)">
						{role.period}
					</span>
				</div>
				<div class="mb-3.5 text-[15px] text-(--muted)">
					{role.company}
				</div>
				<p class="max-w-[62ch] text-pretty text-[16px] leading-[1.6] text-(--ink-soft)">
					{role.before}
					<span class="font-medium text-(--accent)">
						{role.metric}
					</span>
					{role.after}
				</p>
			</div>
		))
	}
</section>
